/**
 * xAgt 配置文件
 *
 * 放在项目根目录 `.opencode/xagt.config.jsonc` 或全局 `~/.config/opencode/xagt.config.jsonc`
 * 插件启动时自动加载，合并到 Agent 配置中。
 */
{
  // ─── 模型映射 ───────────────────────────────────────
  // 给每个 Agent 指定模型。格式：provider/model
  // 不配的 Agent 使用插件硬编码默认模型
  "model": {
    "vox": "deepseek/deepseek-chat",
    "lynx": "anthropic/claude-sonnet-4-20250514",
    "fixer": "openai/gpt-5.4-06-18"
  },

  // ─── provider 配置 ──────────────────────────────────
  // 如果有自定义 provider（如私有部署的 LLM），在这里配
  // 格式参考 opencode.jsonc 的 provider 字段
  "provider": {
    "my-company": {
      "api": "sk-xxxx",
      "baseURL": "https://llm.mycompany.com/v1"
    }
  },

  // ─── MCP 分配 ───────────────────────────────────────
  // 控制每个 Agent 能访问哪些 MCP 服务
  // true  = 允许
  // false = 拒绝（不配也视为拒绝）
  "mcp": {
    "vox": {
      // 总指挥不需要直接调 MCP
    },
    "lynx": {
      "context7": true,
      "gh_grep": true,
      "shadcn-vue": true
    },
    "fixer": {
      "shadcn-vue": true,
      "playwright": true
    }
  }
}
